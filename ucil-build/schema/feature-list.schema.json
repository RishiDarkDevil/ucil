{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ucil.dev/schemas/feature-list.schema.json",
  "title": "UCIL Feature List Oracle",
  "type": "object",
  "required": ["version", "frozen_at", "features"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "frozen_at": { "type": "string", "format": "date-time" },
    "frozen_commit": { "type": ["string", "null"] },
    "source_plan_sha256": { "type": ["string", "null"] },
    "features": {
      "type": "array",
      "items": { "$ref": "#/$defs/feature" }
    }
  },
  "$defs": {
    "feature": {
      "type": "object",
      "required": [
        "id", "phase", "week", "crate", "description", "acceptance_tests",
        "dependencies", "passes", "last_verified_ts", "last_verified_by",
        "last_verified_commit", "attempts", "blocked_reason"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^P[0-9](\\.[0-9])?-W[0-9]+-F[0-9]+$" },
        "phase": { "type": "number" },
        "week": { "type": "number" },
        "crate": { "type": "string" },
        "description": { "type": "string", "minLength": 10 },
        "acceptance_tests": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/acceptance_test" }
        },
        "dependencies": {
          "type": "array",
          "items": { "type": "string", "pattern": "^P[0-9](\\.[0-9])?-W[0-9]+-F[0-9]+$" }
        },
        "passes": { "type": "boolean" },
        "last_verified_ts": { "type": ["string", "null"], "format": "date-time" },
        "last_verified_by": { "type": ["string", "null"] },
        "last_verified_commit": { "type": ["string", "null"] },
        "attempts": { "type": "integer", "minimum": 0 },
        "blocked_reason": { "type": ["string", "null"] }
      }
    },
    "acceptance_test": {
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "selector"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "cargo_test" },
            "selector": { "type": "string" }
          }
        },
        {
          "type": "object",
          "required": ["kind", "selector"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "pytest" },
            "selector": { "type": "string" }
          }
        },
        {
          "type": "object",
          "required": ["kind", "selector"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "vitest" },
            "selector": { "type": "string" }
          }
        },
        {
          "type": "object",
          "required": ["kind", "script", "exit"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "script" },
            "script": { "type": "string" },
            "path": { "type": "string" },
            "exit": { "type": "integer" }
          }
        },
        {
          "type": "object",
          "required": ["kind", "script", "assert"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "bench" },
            "script": { "type": "string" },
            "assert": { "type": "string" }
          }
        }
      ]
    }
  }
}
