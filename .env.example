# Copy to .env and fill. .env is gitignored.

# Claude Code auth — provide EITHER one (OAuth preferred for Max/Team plans):
# Get your OAuth token with:  claude setup-token
CLAUDE_CODE_OAUTH_TOKEN=
# ...or a raw API key:
# ANTHROPIC_API_KEY=sk-ant-...

# Required
GITHUB_TOKEN=ghp_...

# Optional — only if you want the build session to use a GitHub repo for push target
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=ucil
GITHUB_REPO_PRIVATE=true

# Optional — override default model for subagents (all default to opus-4-6)
# CLAUDE_CODE_PLANNER_MODEL=opus-4-6
# CLAUDE_CODE_EXECUTOR_MODEL=opus-4-6
# CLAUDE_CODE_VERIFIER_MODEL=opus-4-6

# --- Cost control ---
# Daily USD spend cap (computed from ~/.claude/projects/*/*.jsonl tokens).
# When exceeded, run-phase.sh writes a blocks_loop=true escalation and halts.
# See scripts/_cost-budget.sh + scripts/cost-summary.sh.
DAILY_USD_CAP=50

# --- OpenTelemetry (optional) ---
# Opt in by setting OTEL_ENABLED=1 + launching a collector via
# `scripts/_otel-collector.sh start` (docker). Claude Code's native OTel
# exporter (CLAUDE_CODE_ENABLE_TELEMETRY=1, auto-set by every launcher) ships
# traces/metrics to OTEL_EXPORTER_OTLP_ENDPOINT. Every launcher also mints or
# propagates a W3C traceparent so all agents on one WO share a trace.
OTEL_ENABLED=0
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_RESOURCE_ATTRIBUTES=service.name=ucil-build,phase=auto

# Langfuse cloud credentials (if set, _otel-collector.sh exports there
# instead of local Jaeger). Get keys from https://cloud.langfuse.com/
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
