#!/usr/bin/env bash
# Gitleaks staged-scan; also cheap regex for common bare keys.
set -euo pipefail

if command -v gitleaks >/dev/null 2>&1; then
  if ! gitleaks protect --staged --no-banner --redact -v 2>/dev/null; then
    echo "[pre-commit-secret-scan] gitleaks detected secrets in staged changes." >&2
    exit 1
  fi
  exit 0
fi

# Fallback if gitleaks not installed: cheap regex scan of staged diff.
STAGED_DIFF=$(git diff --cached -U0 --diff-filter=AM)

# Common patterns (keep narrow to avoid false positives)
PATTERNS=(
  'sk-[a-zA-Z0-9]{20,}'                          # generic API keys
  'sk-ant-[a-zA-Z0-9_-]{20,}'                    # Anthropic
  'ghp_[a-zA-Z0-9]{36}'                          # GitHub PAT
  'github_pat_[a-zA-Z0-9_]{22,}'                 # GitHub fine-grained PAT
  'AKIA[0-9A-Z]{16}'                             # AWS access key
  '-----BEGIN (RSA |OPENSSH |DSA |EC )?PRIVATE KEY-----'
  'xox[baprs]-[a-zA-Z0-9-]{10,}'                 # Slack
)
HITS=()
for p in "${PATTERNS[@]}"; do
  while IFS= read -r line; do
    [[ -n "$line" ]] && HITS+=("$line")
  done < <(echo "$STAGED_DIFF" | grep -E -e "$p" || true)
done

if (( ${#HITS[@]} > 0 )); then
  echo "[pre-commit-secret-scan] suspected secret(s) in staged diff:" >&2
  printf '  %s\n' "${HITS[@]}" >&2
  echo "Install gitleaks for authoritative scanning: https://github.com/gitleaks/gitleaks" >&2
  exit 1
fi

exit 0
