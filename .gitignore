# --- Rust ---
debug/
target/
**/*.rs.bk
*.pdb
**/mutants.out*/
# llvm-cov / cargo llvm-cov coverage instrumentation droppings
*.profraw
**/*.profraw

# --- Node / TypeScript ---
node_modules/
dist/
.turbo/
*.tsbuildinfo
.vite/

# --- Python ---
__pycache__/
*.pyc
.venv/
.uv/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# --- Secrets / local config ---
.env
.env.local
.env.*.local
.claude/settings.local.json

# --- UCIL runtime (per-project) ---
.ucil/

# --- Serena per-project cache (written by `serena-mcp-server --project .`) ---
.serena/

# --- Adapter build outputs ---
adapters/*/dist/

# --- Build harness scratch ---
ucil-build/telemetry/
ucil-build/runs/
ucil-build/.verifier-lock
ucil-build/.watchdog.pid
ucil-build/drift-counters.json

# Triage-pass counters (per phase, transient)
.ucil-triage-pass.phase-*

# --- Editor / OS ---
.DS_Store
.vscode/
.idea/
*.swp

# Claude Code runtime lock
.claude/scheduled_tasks.lock
